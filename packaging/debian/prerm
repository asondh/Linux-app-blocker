#!/bin/sh
# Pre-removal: stop and disable the enforcement service.
set -e

case "$1" in
    remove|deconfigure)
        if [ -d /run/systemd/system ]; then
            systemctl disable --now appblocker.service || true
        fi
        # Remove website blocks from /etc/hosts and browser lockdown policies.
        [ -x /usr/bin/appblocker ] && /usr/bin/appblocker --web-clear || true
        [ -x /usr/bin/appblocker ] && /usr/bin/appblocker --lockdown-clear || true
        ;;
    upgrade)
        # On upgrade, only STOP the old binary so the new one can take over —
        # do NOT disable. Disabling here and re-enabling in postinst is fragile:
        # if that handoff is ever missed, the service is left off at boot (no
        # monitoring, no alerts). Keeping it enabled and just restarting is safe.
        if [ -d /run/systemd/system ]; then
            systemctl stop appblocker.service || true
        fi
        ;;
esac

exit 0
